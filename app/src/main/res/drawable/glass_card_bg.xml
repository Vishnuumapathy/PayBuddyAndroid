<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Translucent gradient for depth: light highlight to deep navy -->
    <gradient
        android:startColor="#26FFFFFF"
        android:centerColor="@color/glass_bg"
        android:endColor="@color/glass_bg"
        android:angle="135" />

    <corners android:radius="24dp" />

    <stroke
        android:width="1dp"
        android:color="#4DFFFFFF" /> <!-- Slightly more visible white edge -->
</shape>

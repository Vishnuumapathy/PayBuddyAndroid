<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/splashFragment">

    <fragment
        android:id="@+id/splashFragment"
        android:name="com.paybuddy.ui.auth.SplashFragment"
        android:label="SplashFragment"
        tools:layout="@layout/fragment_splash">
        <action
            android:id="@+id/action_splash_to_login"
            app:destination="@id/loginFragment"
            app:popUpTo="@id/splashFragment"
            app:popUpToInclusive="true" />
        <action
            android:id="@+id/action_splash_to_dashboard"
            app:destination="@id/dashboardFragment"
            app:popUpTo="@id/splashFragment"
            app:popUpToInclusive="true" />
        <action
            android:id="@+id/action_splash_to_onboarding"
            app:destination="@id/onboardingFragment"
            app:popUpTo="@id/splashFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/loginFragment"
        android:name="com.paybuddy.ui.auth.LoginFragment"
        android:label="Login"
        tools:layout="@layout/fragment_login">
        <action
            android:id="@+id/action_login_to_onboarding"
            app:destination="@id/onboardingFragment" />
        <action
            android:id="@+id/action_login_to_dashboard"
            app:destination="@id/dashboardFragment"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true" />
        <action
            android:id="@+id/action_login_to_register"
            app:destination="@id/registerFragment" />
    </fragment>

    <fragment
        android:id="@+id/registerFragment"
        android:name="com.paybuddy.ui.auth.RegisterFragment"
        android:label="Register"
        tools:layout="@layout/fragment_register">
        <action
            android:id="@+id/action_register_to_onboarding"
            app:destination="@id/onboardingFragment"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/onboardingFragment"
        android:name="com.paybuddy.ui.auth.OnboardingFragment"
        android:label="Vendor Setup"
        tools:layout="@layout/fragment_onboarding">
        <action
            android:id="@+id/action_onboarding_to_dashboard"
            app:destination="@id/dashboardFragment"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/dashboardFragment"
        android:name="com.paybuddy.ui.dashboard.DashboardFragment"
        android:label="Dashboard"
        tools:layout="@layout/fragment_dashboard">
        <action
            android:id="@+id/action_dashboard_to_newSale"
            app:destination="@id/newSaleFragment" />
    </fragment>

    <fragment
        android:id="@+id/salesFragment"
        android:name="com.paybuddy.ui.sales.SalesFragment"
        android:label="Sales"
        tools:layout="@layout/fragment_sales">
        <action
            android:id="@+id/action_salesFragment_to_newSaleFragment"
            app:destination="@id/newSaleFragment" />
        <action
            android:id="@+id/action_salesFragment_to_saleDetailFragment"
            app:destination="@id/saleDetailFragment" />
    </fragment>

    <fragment
        android:id="@+id/saleDetailFragment"
        android:name="com.paybuddy.ui.sales.SaleDetailFragment"
        android:label="Sale Details">
        <argument
            android:name="saleId"
            app:argType="string" />
        <action
            android:id="@+id/action_saleDetailFragment_to_paymentEntryFragment"
            app:destination="@id/paymentEntryFragment" />
    </fragment>

    <fragment
        android:id="@+id/newSaleFragment"
        android:name="com.paybuddy.ui.sales.NewSaleFragment"
        android:label="New Sale"
        tools:layout="@layout/fragment_new_sale">
        <action
            android:id="@+id/action_newSaleFragment_to_addCustomerFragment"
            app:destination="@id/addCustomerFragment" />
    </fragment>

    <fragment
        android:id="@+id/customerFragment"
        android:name="com.paybuddy.ui.customer.CustomerFragment"
        android:label="Customers"
        tools:layout="@layout/fragment_customer">
        <action
            android:id="@+id/action_customerFragment_to_customerProfileFragment"
            app:destination="@id/customerProfileFragment" />
        <action
            android:id="@+id/action_customerFragment_to_addCustomerFragment"
            app:destination="@id/addCustomerFragment" />
    </fragment>

    <fragment
        android:id="@+id/addCustomerFragment"
        android:name="com.paybuddy.ui.customer.AddCustomerFragment"
        android:label="Add Customer" />

    <fragment
        android:id="@+id/customerProfileFragment"
        android:name="com.paybuddy.ui.customer.CustomerProfileFragment"
        android:label="Customer Profile">
        <argument
            android:name="customerId"
            app:argType="string" />
        <action
            android:id="@+id/action_customerProfileFragment_to_paymentEntryFragment"
            app:destination="@id/paymentEntryFragment" />
        <action
            android:id="@+id/action_customerProfileFragment_to_customerSalesListFragment"
            app:destination="@id/customerSalesListFragment" />
        <action
            android:id="@+id/action_customerProfileFragment_to_ledgerFragment"
            app:destination="@id/ledgerFragment" />
    </fragment>

    <fragment
        android:id="@+id/customerSalesListFragment"
        android:name="com.paybuddy.ui.customer.CustomerSalesListFragment"
        android:label="Customer Sales">
        <argument
            android:name="customerId"
            app:argType="string" />
    </fragment>

    <fragment
        android:id="@+id/paymentEntryFragment"
        android:name="com.paybuddy.ui.customer.PaymentEntryFragment"
        android:label="Record Payment">
        <argument
            android:name="customerId"
            app:argType="string" />
        <argument
            android:name="saleId"
            app:argType="string"
            app:nullable="true"
            android:defaultValue="@null" />
    </fragment>

    <fragment
        android:id="@+id/ledgerFragment"
        android:name="com.paybuddy.ui.ledger.LedgerFragment"
        android:label="Ledger History">
        <argument
            android:name="customerId"
            app:argType="string" />
        <argument
            android:name="customerName"
            app:argType="string" />
    </fragment>

    <fragment
        android:id="@+id/reminderFragment"
        android:name="com.paybuddy.ui.reminders.ReminderFragment"
        android:label="Reminders"
        tools:layout="@layout/fragment_reminder" />

    <fragment
        android:id="@+id/settingsFragment"
        android:name="com.paybuddy.ui.settings.SettingsFragment"
        android:label="Settings"
        tools:layout="@layout/fragment_settings">
        <action
            android:id="@+id/action_settings_to_businessProfile"
            app:destination="@id/businessProfileFragment" />
        <action
            android:id="@+id/action_settings_to_securityNotifications"
            app:destination="@id/securityNotificationsFragment" />
        <action
            android:id="@+id/action_settings_to_archivedRecords"
            app:destination="@id/archivedRecordsFragment" />
    </fragment>

    <fragment
        android:id="@+id/archivedRecordsFragment"
        android:name="com.paybuddy.ui.settings.ArchivedRecordsFragment"
        android:label="Archived Records" />

    <fragment
        android:id="@+id/businessProfileFragment"
        android:name="com.paybuddy.ui.settings.BusinessProfileFragment"
        android:label="Business Profile" />

    <fragment
        android:id="@+id/securityNotificationsFragment"
        android:name="com.paybuddy.ui.settings.SecurityNotificationsFragment"
        android:label="Security &amp; Notifications" />

</navigation>
<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/main_bg_gradient"
    android:padding="20dp">

    <TextView
        android:id="@+id/tv_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Reminders"
        android:textColor="@color/text_primary"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Tabs for Due Today, Upcoming, Overdue -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tab_reminders"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:background="@color/transparent"
        app:layout_constraintTop_toBottomOf="@id/tv_title"
        app:tabIndicatorColor="@color/neon_blue"
        app:tabSelectedTextColor="@color/neon_blue"
        app:tabTextColor="@color/text_secondary">
        <com.google.android.material.tabs.TabItem android:text="Due Today" />
        <com.google.android.material.tabs.TabItem android:text="Upcoming" />
        <com.google.android.material.tabs.TabItem android:text="Overdue" />
    </com.google.android.material.tabs.TabLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_reminders"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tab_reminders" />

</androidx.constraintlayout.widget.ConstraintLayout>
